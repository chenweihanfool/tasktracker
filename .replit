entrypoint = "scripts/start-vikunja.sh"
run = ["bash", "scripts/start-vikunja.sh"]
modules = ["bash", "nodejs-20"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 3456
externalPort = 80

[[ports]]
localPort = 3457
externalPort = 3000

# Autoscale is stateless per-instance (scales to zero when idle, fresh
# container on cold start), so ALL state must live outside the compute
# instance: Replit's managed Postgres (provision it via the Database pane —
# this sets DATABASE_URL) instead of a local SQLite file, and a fixed
# VIKUNJA_SERVICE_SECRET set as a Replit Secret instead of an
# auto-generated one written to disk. See scripts/start-vikunja.sh and
# README.md for details and for the (more expensive) Reserved VM + SQLite
# alternative if you ever want it instead.
[deployment]
deploymentTarget = "autoscale"
build = ["bash", "scripts/install-vikunja.sh"]
run = ["bash", "scripts/start-vikunja.sh"]

[agent]
expertMode = true
